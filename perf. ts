type SoakContext = {
  search: Search;
  searchCriteriaModal: SearchCriteriaModal;
  filters: Filters;
  messageList: MessageList;
  message: Message;
};

type SoakHandler = (ctx: SoakContext, hoursToRun: number) => Promise<void>;

type SoakLoopArgs = {
  hoursToRun: number;
  activeMs: number;
  idle: () => Promise<void>;
  beforeActiveWindow?: () => Promise<void>;
  action: () => Promise<void>;
};

const MS_PER_MIN = 60_000;
const MS_PER_HOUR = 60 * MS_PER_MIN;

const ACTIVE_MS = 30 * MS_PER_MIN;
const IDLE_TIME_MINS = 5;

function nowMs(): number {
  return Date.now();
}

function toEndMs(hoursToRun: number): number {
  return nowMs() + Math.max(0, hoursToRun) * MS_PER_HOUR;
}

async function runSoakLoop(args: SoakLoopArgs): Promise<void> {
  const endMs = toEndMs(args.hoursToRun);

  while (nowMs() < endMs) {
    const windowEndMs = nowMs() + args.activeMs;

    if (args.beforeActiveWindow) await args.beforeActiveWindow();
    await args.idle();

    while (nowMs() < windowEndMs && nowMs() < endMs) {
      await args.action();
    }
  }
}

function idleFn(search: Search): () => Promise<void> {
  return async () => waitForMinutes(search, IDLE_TIME_MINS);
}

function scenarioOpenAndCloseSCM(): SoakHandler {
  return async ({ search, searchCriteriaModal }, hoursToRun) =>
    runSoakLoop({
      hoursToRun,
      activeMs: ACTIVE_MS,
      idle: idleFn(search),
      action: async () => openAndCloseSCM(searchCriteriaModal),
    });
}

function scenarioSwitchBetweenMessagesInMessageList(): SoakHandler {
  return async ({ search, searchCriteriaModal, filters, messageList, message }, hoursToRun) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoakLoop({
      hoursToRun,
      activeMs: ACTIVE_MS,
      idle: idleFn(search),
      action: async () => switchBetweenMessagesInMessageList(messageList, message),
    });
  };
}

function scenarioSwitchBetweenAIMessageOptions(): SoakHandler {
  return async ({ search, searchCriteriaModal, filters, message }, hoursToRun) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoakLoop({
      hoursToRun,
      activeMs: ACTIVE_MS,
      idle: idleFn(search),
      action: async () => switchBetweenAIMessageOptions(message),
    });
  };
}

function scenarioSwitchMessageTopicLengthsAndGenerate(): SoakHandler {
  return async ({ search, searchCriteriaModal, filters, message }, hoursToRun) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoakLoop({
      hoursToRun,
      activeMs: ACTIVE_MS,
      idle: idleFn(search),
      beforeActiveWindow: async () => selectNavBarOption(message, "Message summary"),
      action: async () => switchMessageTopicLengthsAndGenerate(message),
    });
  };
}

function scenarioNavigateMessages(): SoakHandler {
  return async ({ search, searchCriteriaModal, filters, message, messageList }, hoursToRun) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoakLoop({
      hoursToRun,
      activeMs: ACTIVE_MS,
      idle: idleFn(search),
      action: async () => {
        await navigateToLastMessage(message, messageList);
        await navigateToFirstMessage(message, messageList);
      },
    });
  };
}

function scenarios(): Record<string, SoakHandler> {
  return {
    OpenAndCloseSCM: scenarioOpenAndCloseSCM(),
    SwitchBetweenMessagesInMessageList: scenarioSwitchBetweenMessagesInMessageList(),
    SwitchBetweenAIMessageOptions: scenarioSwitchBetweenAIMessageOptions(),
    SwitchMessageTopicLengthsAndGenerate: scenarioSwitchMessageTopicLengthsAndGenerate(),
    NavigateMessages: scenarioNavigateMessages(),
  };
}

function requireScenario(map: Record<string, SoakHandler>, scenario: string): SoakHandler {
  const handler = map[scenario];
  if (!handler) throw new Error(`Unknown soak scenario: ${scenario}`);
  return handler;
}

function parseHours(raw: unknown): number {
  const n = typeof raw === "number" ? raw : Number(raw);
  if (!Number.isFinite(n) || n <= 0) throw new Error(`Invalid hours: ${raw}`);
  return n;
}

const soakScenarios = scenarios();

Given(
  /^I start the (.+) soak test for (.+) hrs$/,
  async (ctx: SoakContext, scenarioRaw: string, hoursRaw: unknown) => {
    startSnapshots();
    try {
      const scenario = String(scenarioRaw).trim();
      const hoursToRun = parseHours(hoursRaw);
      await requireScenario(soakScenarios, scenario)(ctx, hoursToRun);
    } finally {
      stopSnapshots();
    }
  }
);