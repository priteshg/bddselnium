type SoakContext = {
  search: Search;
  searchCriteriaModal: SearchCriteriaModal;
  filters: Filters;
  messageList: MessageList;
  message: Message;
};

type SoakHandler = (ctx: SoakContext, hours: number) => Promise<void>;

const MS_PER_MIN = 60_000;
const MS_PER_HOUR = 60 * MS_PER_MIN;

const ACTIVE_MS = 30 * MS_PER_MIN;
const IDLE_TIME_MINS = 5;

function now(): number {
  return Date.now();
}

async function runSoak(
  hours: number,
  idle: () => Promise<void>,
  action: () => Promise<void>,
  beforeActive?: () => Promise<void>
): Promise<void> {
  const end = now() + hours * MS_PER_HOUR;

  while (now() < end) {
    const activeEnd = now() + ACTIVE_MS;

    if (beforeActive) await beforeActive();
    await idle();

    while (now() < activeEnd && now() < end) {
      await action();
    }
  }
}

const scenarios: Record<string, SoakHandler> = {
  OpenAndCloseSCM: async ({ search, searchCriteriaModal }, hours) => {
    await runSoak(
      hours,
      () => waitForMinutes(search, IDLE_TIME_MINS),
      () => openAndCloseSCM(searchCriteriaModal)
    );
  },

  SwitchBetweenMessagesInMessageList: async (
    { search, searchCriteriaModal, filters, messageList, message },
    hours
  ) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoak(
      hours,
      () => waitForMinutes(search, IDLE_TIME_MINS),
      () => switchBetweenMessagesInMessageList(messageList, message)
    );
  },

  SwitchBetweenAIMessageOptions: async (
    { search, searchCriteriaModal, filters, message },
    hours
  ) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoak(
      hours,
      () => waitForMinutes(search, IDLE_TIME_MINS),
      () => switchBetweenAIMessageOptions(message)
    );
  },

  SwitchMessageTopicLengthsAndGenerate: async (
    { search, searchCriteriaModal, filters, message },
    hours
  ) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoak(
      hours,
      () => waitForMinutes(search, IDLE_TIME_MINS),
      () => switchMessageTopicLengthsAndGenerate(message),
      () => selectNavBarOption(message, "Message summary")
    );
  },

  NavigateMessages: async (
    { search, searchCriteriaModal, filters, message, messageList },
    hours
  ) => {
    await searchForOnlyEmail(filters, searchCriteriaModal, search);

    await runSoak(
      hours,
      () => waitForMinutes(search, IDLE_TIME_MINS),
      async () => {
        await navigateToLastMessage(message, messageList);
        await navigateToFirstMessage(message, messageList);
      }
    );
  },
};

Given(
  /^I start the (.+) soak test for (\d+(?:\.\d+)?) hrs$/,
  async (ctx: SoakContext, scenario: string, hoursRaw: string) => {
    startSnapshots();
    try {
      const hours = Number(hoursRaw);
      const handler = scenarios[scenario];

      if (!handler) {
        throw new Error(`Unknown soak scenario: ${scenario}`);
      }

      await handler(ctx, hours);
    } finally {
      stopSnapshots();
    }
  }
);